{
    "name": "jason-guru/laravel-make-repository",
    "description": "A simple package to create a make:repository command for Laravel 10, 11, and 12.",
    "type": "library",
    "keywords": ["laravel", "repository", "make", "command", "eloquent"],
    "license": "MIT",
    "authors": [
        {
            "name": "G Jason Sharma",
            "email": "g.jason.sharma@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "JasonGuru\\LaravelMakeRepository\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JasonGuru\\LaravelMakeRepository\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JasonGuru\\LaravelMakeRepository\\RepositoryServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
